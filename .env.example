# ─── PostgreSQL (used by docker-compose) ──────────────────────────────────────
POSTGRES_USER=taskguard
POSTGRES_PASSWORD=1234Perian
POSTGRES_DB=taskguard_db

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Brevo (email verification) — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# Prisma connection string — in Docker the host is "db" (the service name).
# For local development outside Docker, use "localhost" instead.
DATABASE_URL=postgresql://taskguard:1234Perian@db:5432/taskguard_db

# JWT — generate strong random secrets in production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=5a4a9315ffe3d9b2384fdf5b6a0f4f88a2ce4f11a4f6d38937086e386b9c4521
JWT_REFRESH_SECRET=656912a7d74c20744f9b49dde5b03ffabeb621b2a261bd726815e9bf18c8805b
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=1022948483427-k3ar0hkrdrsnpgngb23qrius7h2f0lc1.apps.googleusercontent.com

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=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

# Firebase Admin SDK — paste the entire service-account JSON as a single line.
# Leave blank to disable push notifications (the app will still work).
FIREBASE_SERVICE_ACCOUNT=
