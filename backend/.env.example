# Server
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Resend (email verification) — https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=TaskGuard AI <onboarding@resend.dev>

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/taskguard_ai?schema=public"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_too

# Google OAuth (for Google Sign-In)
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key_here

# Firebase (for push notifications - paste service account JSON as single line)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
